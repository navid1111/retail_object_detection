# ===========================================
# Apache Airflow Environment Configuration
# ===========================================
# Copy this file to .env before running docker-compose
# cp .env.example .env (Linux/Mac)
# copy .env.example .env (Windows)

# -------------------------------------------
# Airflow Core Configuration
# -------------------------------------------

# User ID for Airflow containers (prevents permission issues on Linux)
# Default: 50000
# On Linux, set to your current user ID: export AIRFLOW_UID=$(id -u)
# On Windows/Mac, keep default
AIRFLOW_UID=50000

# -------------------------------------------
# Airflow Image Configuration (Optional)
# -------------------------------------------

# Custom Docker image name (default uses official Airflow image)
# AIRFLOW_IMAGE_NAME=apache/airflow:3.1.6

# Base path to project directory (default: current directory)
# AIRFLOW_PROJ_DIR=.

# Path to .env file (default: .env)
# ENV_FILE_PATH=.env

# -------------------------------------------
# Admin User Configuration (Optional)
# -------------------------------------------

# Username for Airflow web UI admin account
# Default: airflow
_AIRFLOW_WWW_USER_USERNAME=airflow

# Password for Airflow web UI admin account
# Default: airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow

# -------------------------------------------
# Additional Requirements (Optional)
# -------------------------------------------

# Additional pip packages to install at container startup
# WARNING: Only use for quick tests. For production, extend the Dockerfile.
# Default: ''
# _PIP_ADDITIONAL_REQUIREMENTS=

# -------------------------------------------
# Airflow Configuration (Internal - Do Not Modify)
# -------------------------------------------
# These are set in docker-compose.yml environment section:
# - AIRFLOW__CORE__EXECUTOR=CeleryExecutor
# - AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres/airflow
# - AIRFLOW__CELERY__RESULT_BACKEND=db+postgresql://airflow:airflow@postgres/airflow
# - AIRFLOW__CELERY__BROKER_URL=redis://:@redis:6379/0
# - AIRFLOW__CORE__FERNET_KEY=''
# - AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION='true'
# - AIRFLOW__CORE__LOAD_EXAMPLES='false'
# - AIRFLOW__CORE__EXECUTION_API_SERVER_URL='http://airflow-apiserver:8080/execution/'
# - AIRFLOW__SCHEDULER__ENABLE_HEALTH_CHECK='true'
# - AIRFLOW_CONFIG='/opt/airflow/config/airflow.cfg'
# - PYTHONPATH='/opt/airflow/project'

# -------------------------------------------
# App Runtime Configuration (src.config)
# -------------------------------------------

# Optional YAML config path (default: config/runtime.yaml)
# APP_CONFIG_FILE=config/runtime.yaml

# Optional project root override (default: APP_PROJECT_ROOT or PYTHONPATH or cwd)
# APP_PROJECT_ROOT=/opt/airflow/project

# Dataset & split controls
# APP_DATASET_YAML=dataset/dataset_yolo-20260523T151551Z-3-001/dataset_yolo/data.yaml
# APP_SOURCE_DATASET_DIR=dataset/dataset_yolo-20260523T151551Z-3-001/dataset_yolo
# APP_STRATIFIED_YAML=dataset/dataset_stratified/data.yaml
# APP_STRATIFIED_OUTPUT_DIR=dataset/dataset_stratified
# APP_EXPECTED_CLASSES=2
# APP_TRAIN_RATIO=0.8
# APP_VAL_RATIO=0.1
# APP_TEST_RATIO=0.1
# APP_RANDOM_SEED=42

# Training controls
# APP_MODEL_BASE=yolo11m.pt
# APP_TRAIN_PROJECT=runs/train
# APP_TRAIN_NAME=pipeline_run
# APP_TRAIN_EPOCHS=100
# APP_TRAIN_IMGSZ=640
# APP_TRAIN_BATCH=4
# APP_TRAIN_RESUME=true
# APP_TRAIN_STRICT_RESUME=false
# APP_TRAIN_AMP=true
# APP_TRAIN_PATIENCE=0
# APP_USE_WANDB=true
# APP_TRAIN_DEVICE=0
# APP_TRAIN_WORKERS=0

# W&B metadata
# APP_WANDB_ENTITY=navidkamal-islamic-university-of-technology
# APP_WANDB_PROJECT=retail_object-detection
# WANDB_API_KEY=your_wandb_api_key_here

# Dataset metadata for experiment tracking
# APP_DATASET_VERSION=v1
# DATASET_VERSION=v1

# -------------------------------------------
# Build-time Configuration (Docker ARGs)
# -------------------------------------------

# BUILD_AIRFLOW_BASE_IMAGE=apache/airflow:3.1.6
# BUILD_TORCH_VERSION=2.6.0
# BUILD_TORCHVISION_VERSION=0.21.0
# BUILD_TORCHAUDIO_VERSION=2.6.0
